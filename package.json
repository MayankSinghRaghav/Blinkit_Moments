{
  "name": "blinkit-moments",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "eval": "tsx evals/run.ts",
    "eval:live": "tsx evals/run.ts --live",
    "db:seed": "tsx --env-file-if-exists=.env.local scripts/seed.ts",
    "verify:store": "tsx --conditions=react-server --env-file-if-exists=.env.local scripts/verify-store.ts",
    "discovery:tag": "node --env-file-if-exists=.env.local scripts/discovery/2-tag.mjs",
    "discovery:analyze": "node scripts/discovery/3-analyze.mjs",
    "discovery:holdout": "node scripts/discovery/4-holdout.mjs",
    "discovery:fetch": "node scripts/discovery/0-fetch-appstore.mjs && node scripts/discovery/1-normalize.mjs",
    "verify:cart": "tsx scripts/verify-cart.ts",
    "verify:quotes": "tsx scripts/verify-quotes.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.58.0",
    "framer-motion": "^12.42.2",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}